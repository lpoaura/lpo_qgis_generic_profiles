{
  "$schema": "https://raw.githubusercontent.com/qgis-deployment/qgis-deployment-toolbelt-cli/refs/heads/main/docs/schemas/profile/qgis_profile.json",
  "name": "pdl_naturaliste",
  "folder_name": "pdl_naturaliste",
  "description": "QGIS profile pour les chargé.e.s de mission Naturaliste à la LPO PDL.",
  "author": "Pôle système d'information",
  "email": "aura.support@lpo.fr",
  "icon": "images/logo_qgis_lpo.ico",
  "qgisMinimumVersion": "3.28.0",
  "qgisMaximumVersion": "3.99.10",
  "version": "1.1.0",
  "plugins": [
    {
      "name": "Plugin LPO",
      "folder_name": "plugin_qgis_lpo",
      "version": "3.9.0",
      "repository_url_xml": "https://github.com/lpoaura/PluginQGis-LPOData/releases/download/3.9.0/plugins.xml",
      "official_repository": false
    },
    {
      "name": "Layers menu from project",
      "folder_name": "menu_from_project",
      "official_repository": true,
      "plugin_id": 43,
      "version": "2.4.1"
    },
    {
      "name": "French Locator Filter",
      "folder_name": "french_locator_filter",
      "official_repository": true,
      "plugin_id": 1846,
      "version": "1.3.0"
    },
    {
      "name": "Group Stats",
      "folder_name": "GroupStats",
      "official_repository": true,
      "plugin_id": 40,
      "version": "2.2.7"
    },
    {
      "name": "Mask",
      "folder_name": "mask",
      "official_repository": true,
      "plugin_id": 65,
      "version": "1.11.0"
    },
    {
      "name": "Layers menu from project",
      "folder_name": "menu_from_project",
      "official_repository": true,
      "plugin_id": 43,
      "version": "2.4.1"
    },
    {
      "name": "Spreadsheet Layers",
      "folder_name": "SpreadsheetLayers",
      "official_repository": true,
      "plugin_id": 766,
      "version": "2.1.2"
    }
  ],
  "rules": [
    {
      "name": "Domaine",
      "description": "Restriction de diffusion sur les groupes AD ou OS ou variable environnement",
      "conditions": {
        "any": [
          {
            "path": "$.user.groups_domain",
            "value": "GG-GPOqgis_admin",
            "operator": "contains"
          },
          {
            "path": "$.environment.operating_system_code",
            "value": "linux",
            "operator": "equal"
          },
          {
            "path": "$.env.QDT_LPO",
            "operator": "equal",
            "value": "lpo_pdl"
          }
        ]
      }
    }
  ]
}
